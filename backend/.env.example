FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\firebase-service-account.json
APP_STORAGE_DIR=C:\path\to\academic-data-storage
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.onrender.com
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Optional alternative to FIREBASE_SERVICE_ACCOUNT_PATH:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
